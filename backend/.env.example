# ── Telegram ──────────────────────────────────
# Токен бота від @BotFather
TELEGRAM_BOT_TOKEN=
# Необов'язково: chat_id за замовчуванням (бот сам бере id того, хто пише)
TELEGRAM_CHAT_ID=0

# ── Mini App ──────────────────────────────────
# URL фронтенду на Vercel, напр. https://uz-tickets.vercel.app
WEBAPP_URL=
# Дозволені Origin для CORS (через кому). Порожньо = WEBAPP_URL.
CORS_ORIGINS=

# ── Моніторинг ────────────────────────────────
CHECK_INTERVAL=60
MAX_ROUTES=10
HEADLESS=true

# Проксі для браузера (обхід Cloudflare). ТІЛЬКИ резидентний/мобільний!
# Датацентровий (звичайний UA-проксі) Cloudflare ріже так само.
# Формат: http://user:pass@host:port  або  socks5://user:pass@host:port
PROXY=

# ── Сервер ────────────────────────────────────
# PORT Railway виставляє автоматично; локально можна 8080
PORT=8080
HOST=0.0.0.0

# ── Сховище ───────────────────────────────────
DB_PATH=uz_bot.db
